<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.simsekolah.ui.home.HomeFragment"
        android:label="@string/home"
        tools:layout="@layout/fragment_home" />
        
    <fragment
        android:id="@+id/scheduleFragment"
        android:name="com.example.simsekolah.ui.schedule.ScheduleFragment"
        android:label="@string/schedule"
        tools:layout="@layout/fragment_schedule">
        <action
            android:id="@+id/action_scheduleFragment_to_editScheduleFragment"
            app:destination="@id/editScheduleFragment" />
    </fragment>

    <fragment
        android:id="@+id/editScheduleFragment"
        android:name="com.example.simsekolah.ui.schedule.EditScheduleFragment"
        android:label="Edit Schedule"
        tools:layout="@layout/fragment_edit_schedule">
        <argument
            android:name="day_name"
            app:argType="string" />
        <argument
            android:name="schedule_json"
            app:argType="string" />
    </fragment>
        
    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.example.simsekolah.ui.attendance.AttendanceFragment"
        android:label="@string/attendance"
        tools:layout="@layout/fragment_attendance">
        <action
            android:id="@+id/action_attendanceFragment_to_takeAttendanceFragment"
            app:destination="@id/takeAttendanceFragment" />
    </fragment>

    <fragment
        android:id="@+id/takeAttendanceFragment"
        android:name="com.example.simsekolah.ui.attendance.TakeAttendanceFragment"
        android:label="Take Attendance"
        tools:layout="@layout/fragment_teacher_take_attendance" />
        
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.simsekolah.ui.main.ProfileFragment"
        android:label="@string/profile"
        tools:layout="@layout/fragment_profile" />

    <activity
        android:id="@+id/loginActivity"
        android:name="com.example.simsekolah.ui.auth.LoginActivity"
        android:label="activity_login"
        tools:layout="@layout/activity_login" />
        
    <activity
        android:id="@+id/registerActivity"
        android:name="com.example.simsekolah.ui.auth.RegisterActivity"
        android:label="activity_register"
        tools:layout="@layout/activity_register" />
        
    <fragment
        android:id="@+id/assignmentsFragment"
        android:name="com.example.simsekolah.ui.assignment.AssignmentsFragment"
        android:label="fragment_assignments"
        tools:layout="@layout/fragment_assignments" />
        
    <fragment
        android:id="@+id/eventFragment"
        android:name="com.example.simsekolah.ui.event.EventFragment"
        android:label="fragment_event"
        tools:layout="@layout/fragment_event" />
        
    <fragment
        android:id="@+id/feesFragment"
        android:name="com.example.simsekolah.ui.fees.FeesFragment"
        android:label="fragment_fees"
        tools:layout="@layout/fragment_fees" />

</navigation>